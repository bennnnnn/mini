# Mini Cursor - Environment Configuration
# Copy to .env and fill in values

# Application
APP_NAME=Mini Cursor
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-string

# Database
DATABASE_URL=postgresql+asyncpg://mini_cursor:changeme@postgres:5432/mini_cursor

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/github/callback

# Anthropic
ANTHROPIC_API_KEY=

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Docker
DOCKER_EXECUTOR_IMAGE=mini-cursor-executor:latest
DOCKER_EXECUTOR_TIMEOUT=120
DOCKER_EXECUTOR_MEMORY_LIMIT=512m
DOCKER_EXECUTOR_CPU_LIMIT=1

# Rate Limits (free tier)
RATE_LIMIT_API_DAILY=100
RATE_LIMIT_AGENT_DAILY=20
RATE_LIMIT_EXECUTION_DAILY=20
RATE_LIMIT_PR_DAILY=10
